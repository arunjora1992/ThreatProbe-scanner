# Copy to .env and adjust for your deployment.

# --- Database ---
POSTGRES_USER=pentest
POSTGRES_PASSWORD=change-this-strong-password
POSTGRES_DB=pentest

# --- Backend / auth ---
# Generate a long random value, e.g.:  openssl rand -hex 32
SECRET_KEY=change-me-to-a-long-random-secret

# Bootstrap admin account (created on first start only)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password

# --- Frontend ---
# HTTP port (redirects to HTTPS)
FRONTEND_PORT=8080
# HTTPS port the GUI is served on (self-signed certificate, generated at first start)
FRONTEND_HTTPS_PORT=8443
